APP_NAME=openclaw-client
ENV=dev
HOST=0.0.0.0
PORT=8787

DATABASE_URL=postgresql+asyncpg://postgres:postgres@127.0.0.1:5432/openclaw_client
# Redis config (Redis 8 supported)
# Option A: use full URL
# REDIS_URL=redis://:your_password@127.0.0.1:6379/10
# Option B: split fields (recommended when injecting secret separately)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=10
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_SSL=false

JWT_SECRET=please-change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720

# bootstrap admin account (created/updated on startup)
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123456
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_DISPLAY_NAME=Admin

# for OBS/S3 compatible endpoint test:
OBS_VERIFY_SSL=false
